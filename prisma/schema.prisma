// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int     @id @default(autoincrement())
  email     String  @unique
  password  String
  firstname String?
  lastname  String?
}

model Continent {
  id        Int        @id @default(autoincrement())
  name      String
  waterWays WaterWay[]
}

model WaterWay {
  id          Int       @id @default(autoincrement())
  name        String
  lenght      Decimal
  description String
  ph          Decimal
  temperature Decimal
  turbidity   Decimal
  longitude   Decimal
  latitude    Decimal
  cover       String
  continent   Continent @relation(fields: [continentId], references: [id])
  continentId Int
  Species     Species[]
}

model Species {
  id          Int        @id @default(autoincrement())
  name        String
  cover       String
  description String
  waterWays   WaterWay[]
}

model Subject {
  id    Int    @id @default(autoincrement())
  name  String
  cover String
}

model Lesson {
  id          Int    @id @default(autoincrement())
  index       Int
  title       String
  duration    String
  contentText String
  tips        Tip[]
}

model Tip {
  id       Int      @id @default(autoincrement())
  title    String
  texts    String[]
  Lesson   Lesson?  @relation(fields: [lessonId], references: [id])
  lessonId Int?
}

model LessonCompletion {
  id        Int     @id @default(autoincrement())
  userId    Int
  lessonId  Int
  completed Boolean
}
